#!/usr/bin/env sh
# Cross-Stitch repo pre-commit hook (Husky 9+).
# Husky 9 dropped the husky.sh shim, so this is a plain shell script.
# A shebang + executable bit are required for Git to exec it on Unix.
# Runs the terminology lint so violations fail commits locally
# (mirrors the CI check). To bypass once, use `git commit --no-verify`.

# Only run if there are staged files that the linter watches.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|md|html)$' || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

if ! node scripts/lint-terminology.js; then
  echo ""
  echo "✗ Pre-commit blocked: terminology lint failed."
  echo "  Fix the listed file:line entries (or add '// terminology-lint-allow' to the line"
  echo "  if the term is intentional) and try again. To bypass once, use git commit --no-verify."
  exit 1
fi

exit 0
