{
  "name": "app",
  "version": "1.0.0",
  "description": "stitchx: A feature-rich, single-file web application for creating, managing, and tracking cross-stitch patterns directly from your browser.",
  "main": "colour-utils.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "start": "node serve.js",
    "test": "jest",
    "test:silent": "jest --runInBand --silent",
    "test:e2e": "playwright test --project=touch-tablet-chromium",
    "perf:baseline": "playwright test --project=perf-desktop",
    "perf:mobile": "playwright test --project=perf-mobile",
    "lint:terminology": "node scripts/lint-terminology.js",
    "lint:css-tokens": "node scripts/lint-css-tokens.js",
    "build:creator": "node build-creator-bundle.js",
    "build": "node build-creator-bundle.js",
    "prepare": "node scripts/install-hooks.js"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/",
      "/tests/perf/"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kate-nc/cross-stitch.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Kate-nc/cross-stitch/issues"
  },
  "homepage": "https://github.com/Kate-nc/cross-stitch#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@playwright/test": "^1.59.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "opentype.js": "^1.3.4",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
